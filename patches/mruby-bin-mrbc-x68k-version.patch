+
+#ifndef MRBC_X68K_MIN_COMPILE_BLOCK
+#define MRBC_X68K_MIN_COMPILE_BLOCK (128L * 1024L)
+#endif
+
+#define MRBC_X68K_COMPILE_MARGIN (64L * 1024L)
+extern void mrb_x68k_memstat_enable(void);
+extern void mrb_x68k_memstat_set_limit(size_t limit);
+
+static long
+x68k_largest_free_block(void)
+{
+  unsigned long raw = (unsigned long)_dos_malloc(-1);
+
+  /*
+   * Human68k _MALLOC returns 0x81000000 + largest-free-size when
+   * allocation fails. Passing -1 intentionally uses that behavior to query
+   * the largest allocatable block.
+   */
+  if ((raw & 0xff000000UL) == 0x81000000UL) {
+    return (long)(raw & 0x00ffffffUL);
+  }
+  return -1;
+}
+
+static long
+x68k_compile_memory_budget(void)
+{
+  long free_block = x68k_largest_free_block();
+
+  if (free_block < MRBC_X68K_MIN_COMPILE_BLOCK) return 0;
+  if (free_block <= MRBC_X68K_COMPILE_MARGIN) return 0;
+
+  return free_block - MRBC_X68K_COMPILE_MARGIN;
+}
+#endif
+
+static void
+x68k_show_version(void)
+{
+  printf("mruby-x68k 0.4.0\n");
+  printf("target: X68000 / Human68k\n");
+}
+
+static void
+x68k_show_core_version(void)
+{
+  printf("%s\n", MRUBY_DESCRIPTION);
+}
+
+static mrb_bool
+x68k_pre_scan_version_only(int argc, char **argv)
+{
+  return argc == 2 && strcmp(argv[1], "--version") == 0;
+}
 
