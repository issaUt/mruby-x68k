+static mrb_bool
+pre_scan_memstat(int argc, char **argv)
+{
+  for (int i = 1; i < argc; i++) {
+    if (strcmp(argv[i], "--") == 0) return FALSE;
+    if (strcmp(argv[i], "--memstat") == 0) return TRUE;
+    if (argv[i][0] != '-') return FALSE;
+  }
+  return FALSE;
+}
+
+static void
+print_memstat(mrb_state *mrb)
+{
+  size_t current = mrb_x68k_memstat_current();
+  size_t peak = mrb_x68k_memstat_peak();
+  size_t total = mrb_x68k_memstat_total();
+
+  mrb_full_gc(mrb);
+  current = mrb_x68k_memstat_current();
+
+  printf("mruby memory:\n");
+  printf("  current: %lu bytes (%lu KB)\n", (unsigned long)current, (unsigned long)((current + 1023) / 1024));
+  printf("  peak:    %lu bytes (%lu KB)\n", (unsigned long)peak, (unsigned long)((peak + 1023) / 1024));
+  printf("  total:   %lu bytes (%lu KB)\n", (unsigned long)total, (unsigned long)((total + 1023) / 1024));
+  printf("  gc live: %lu objects\n", (unsigned long)mrb->gc.live);
+  printf("  arena:   %d objects\n", mrb->gc.arena_idx);
+}
